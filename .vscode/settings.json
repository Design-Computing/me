{
    "python.formatting.provider": "black",
    
    // Pytest configuration for Test Explorer
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": [
        // Use pytest.ini from course folder for configuration
        "-c", "../course/pytest.ini",
        // Discover tests from course folder
        "../course"
    ],
    // Run tests from the me folder so imports work correctly
    "python.testing.cwd": "${workspaceFolder}",
    
    // Auto-discover tests when opening the folder
    "python.testing.autoTestDiscoverOnSaveEnabled": true
}